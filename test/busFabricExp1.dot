digraph G{

	rankdir = "LR"

IP0[label="IP0", type=SOURCE, rate=0.05, cv=0.55, shape="rarrow"];
Temp_buffer0[label="Temp_buffer0", type=QUEUE, depth=12, shape="cylinder"];
BF0_arbiter[label="BF0_arbiter", type=PRioRity, zero_load=34.0, t_serv=0.0, coeff_var=0.0, shape="trapezium"];
BF0_buffer[label="BF0_buffer", type=Queue, depth=12, shape="cylinder"];
BF0_SR[label="BF0_SR", type=Server, t_serv=1.0, coeff_var=0.0, shape="circle"];
DIE0_SR[label="DIE0_SR", type=Server, t_serv=1.0, coeff_var=0.0, shape="circle"];
Sink0[label="DIE0 Sink", type=Sink];

IP0 -> Temp_buffer0;
Temp_buffer0 -> BF0_arbiter;
BF0_arbiter ->BF0_SR;
BF0_SR -> BF0_buffer;
BF0_buffer ->  DIE0_SR;
DIE0_SR -> Sink0;
}

