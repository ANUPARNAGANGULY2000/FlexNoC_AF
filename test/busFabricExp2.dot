BF0_SR[label="BF0_SR", type=Server, t_serv=1.0, coeff_var=0.0, shape="circle"];
BF6_SR[label="BF6_SR", type=Server, t_serv=1.0, coeff_var=0.0, shape="circle"];
BF6_buffer[label="BF6_buffer", type=Queue, depth=12, shape="cylinder"];
BF0_buffer[label="BF0_buffer", type=Queue, depth=12, shape="cylinder"];
